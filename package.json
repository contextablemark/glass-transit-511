{
  "name": "glass-transit-511",
  "version": "0.5.3",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5174",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "qr": "evenhub qr --http --port 5174",
    "pack": "npm run build && evenhub pack app.json dist -o glass-transit.ehpk",
    "build-stations": "tsx scripts/build-stations.ts"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.9",
    "gtfs-realtime-bindings": "^1.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.11",
    "@tailwindcss/vite": "^4.2.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.5.0",
    "jsdom": "^26.1.0",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "vite": "^6.4.0",
    "vitest": "^3.2.1"
  }
}
